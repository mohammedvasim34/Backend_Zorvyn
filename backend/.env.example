# PostgreSQL Database Configuration
# Supabase PostgreSQL (password must be URL encoded)
DATABASE_URL=postgresql://postgres:YOUR_URL_ENCODED_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require
DB_FORCE_IPV4=true
DB_CONNECT_TIMEOUT=10

# JWT Secret Key (change this in production)
JWT_SECRET_KEY=change-this-in-production

# Optional: Database Echo (set to true for SQL query debugging)
# DATABASE_ECHO=false
